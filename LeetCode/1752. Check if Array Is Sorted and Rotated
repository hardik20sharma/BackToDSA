class Solution {
public:
    bool check(vector<int>& nums) {
        
        bool down = false;

        for(int i = 1; i < nums.size(); i++)
            if(nums[i-1] > nums[i] && !down)
                down = true;
            else if(nums[i-1] > nums[i] && down)
                return false;
        
        if(down)
            return nums[0] >= nums[nums.size() - 1];
        else
            return true;
    }
};
