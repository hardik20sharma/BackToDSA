class Solution {

    int sum(int n) {

        int res = 0;

        while(n > 0) {
            res += (n % 10);
            n /= 10;
        }

        return res;
    }

    public int minElement(int[] nums) {
        
        int res = Integer.MAX_VALUE;

        for(int i : nums)
            res = Math.min(res, sum(i));
        
        return res;
    }
}
