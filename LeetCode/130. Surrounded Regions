class Solution {

    int m;
    int n;
    vector<vector<int>> moves;


    bool isSafe(int x, int y) {
        return 0 <= x && x < m && 0 <= y && y < n;
    }

    void dfs(vector<vector<char>> &board, int x, int y) {

        board[x][y] = 'o';

        for(auto move : moves) {
            int i = x + move[0], j = y + move[1];
            
            if(isSafe(i, j) && board[i][j] == 'O')
                dfs(board, i, j);
        }
    }

public:
    void solve(vector<vector<char>>& board) {
        
        m = board.size(); n = board[0].size();
        moves = { {-1, 0}, {1, 0}, {0, -1}, {0, 1} };

        for(int j = 0; j < n; j++) {

            if(board[0][j] == 'O')
                dfs(board, 0, j);

            if(board[m-1][j] == 'O')
                dfs(board, m-1, j);
        }

        for(int i = 0; i < m; i++) {

            if(board[i][0] == 'O')
                dfs(board, i, 0);

            if(board[i][n-1] == 'O')
                dfs(board, i, n-1);
        }

        for(int i = 0; i < m; i++)
            for(int j = 0; j < n; j++)
                if(board[i][j] == 'O')
                    board[i][j] = 'X';
                else if(board[i][j] == 'o')
                    board[i][j] = 'O';
    }
};
