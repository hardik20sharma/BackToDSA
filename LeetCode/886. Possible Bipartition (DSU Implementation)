class DSU {

    vector<int> size;
    vector<int> parent;

public:

    DSU(int n) {
        size.resize(n, 1);
        parent.resize(n, 0);
        for(int i = 0; i < n; i++)
            parent[i] = i;
    }

    int findParent(int x) {

        if(x == parent[x])
            return x;
        
        return parent[x] = findParent(parent[x]);
    }

    void unite(int u, int v) {

        u = findParent(u);
        v = findParent(v);

        if(u == v)
            return;
        
        if(size[u] < size[v]) {
            parent[u] = v;
            size[v] += size[u];
        }
        else {
            parent[v] = u;
            size[u] += size[v];
        }
    }
};

class Solution {
public:
    bool possibleBipartition(int n, vector<vector<int>>& dislikes) {
        
        vector<vector<int>> graph(n);

        for(auto d : dislikes) {
            int u = d[0] - 1, v = d[1] - 1;
            graph[u].push_back(v);
            graph[v].push_back(u);
        }

        DSU dsu(n);

        for(int u = 0; u < n; u++) {

            if (graph[u].empty())
                continue;

            // enemyRep is "the group of people that must be opposite to u"
            int enemyRep = graph[u][0];

            for (int v : graph[u]) {

                // If u and any enemy end up in same set => contradiction
                if (dsu.findParent(u) == dsu.findParent(v)) 
                    return false;

                // All enemies of u must be in the same group (enemyRep's group)
                dsu.unite(enemyRep, v);
            }
        }

        return true;
    }
};
