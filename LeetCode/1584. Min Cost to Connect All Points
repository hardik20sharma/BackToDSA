// Involves Prim's Algorithm. Make sure to revise
#define pii pair<int, int>
class Solution {
public:
    int minCostConnectPoints(vector<vector<int>>& points) {
        
        int n = points.size();
        vector<bool> visited(n, false);

        priority_queue<pii, vector<pii>, greater<pii>> pq;  // {dist, point}
        pq.push( {0, 0} );
        
        int res = 0;

        while(!pq.empty()) {

            auto [dist, curr] = pq.top();
            pq.pop();

            if(visited[curr])
                continue;

            visited[curr] = 1;
            res += dist;

            int x1 = points[curr][0], y1 = points[curr][1];

            for(int i = 0; i < n; i++) {
                if(!visited[i]) {
                    int x2 = points[i][0], y2 = points[i][1];
                    int val = abs(x2 - x1) + abs(y2 - y1);
                    pq.push( {val, i} );
                }
            }
        }

        return res;
    }
};
