// C++ Code

class Solution {
public:
    int minPartitions(string n) {
        
        int res = 0;

        for(char c : n)
            res = max(res, c - '0');
        
        return res;
    }
};

// Java Code

class Solution {
    public int minPartitions(String n) {
        
        int res = 0;

        for(int i = 0; i < n.length(); i++)
            res = Math.max(res, n.charAt(i) - '0');

        return res;
    }
}

// Java code, for version

class Solution {
    public int minPartitions(String n) {
        
        int res = 0;

        for (char c : n.toCharArray())
            res = Math.max(res, c - '0');

        return res;
    }
}
